# ── SteadyFit environment ────────────────────────────────────────────────
# Copy to .env and fill in values:  cp .env.example .env
# .env is gitignored — never commit real secrets.

# ── REQUIRED for basic chat ─────────────────────────────────────────────
# All agent LLM calls go through the Vercel AI Gateway (OpenAI-compatible).
# Create a key: Vercel dashboard → AI Gateway → API Keys
AI_GATEWAY_API_KEY=
# Optional override (default: https://ai-gateway.vercel.sh/v1)
# AI_GATEWAY_BASE_URL=https://ai-gateway.vercel.sh/v1

# ── REQUIRED — Postgres (pgvector + LangGraph checkpointer) ─────────────
# Local Docker:  postgresql://postgres:postgres@localhost:5432/postgres
# Neon prod:     postgresql://USER:PASSWORD@ep-xxx.aws.neon.tech/neondb?sslmode=require
# Run once after the DB is up:  uv run python scripts/init_db.py
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgres

# ── REQUIRED for RAG (uploads / knowledge base retrieval) ───────────────
# Embeddings only (text-embedding-3-small). Chat works without it;
# retrieval returns a tagged error and agents fall back to model knowledge.
OPENAI_API_KEY=

# ── REQUIRED in production — weekly review trigger ──────────────────────
# Shared secret the Render cron job sends in the X-Internal-Secret header.
# Any non-empty value works in dev (e.g. dev-secret).
INTERNAL_CRON_SECRET=dev-secret

# ── OPTIONAL — CORS origin of the Vercel frontend ───────────────────────
# Leave empty in dev — localhost origins are always allowed.
# Production: your Vercel URL, e.g. https://steadyfit.vercel.app
# Multiple origins (custom domain + Vercel): comma-separated
FRONTEND_URL=

# ── OPTIONAL — degrade gracefully when missing ──────────────────────────
TAVILY_API_KEY=
USDA_API_KEY=

# ── OPTIONAL — monitoring (LangSmith traces; off when unset) ────────────
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=steadyfit
# Experiment runner (evals/run_evals.py --experiment):
# LANGSMITH_DATASET=steadyfit-golden
# LANGSMITH_EXPERIMENT_PREFIX=steadyfit-eval
# LANGSMITH_MAX_CONCURRENCY=1

# ── OPTIONAL — blast-radius / abuse controls ────────────────────────────
# Max characters accepted per chat message (default 2000)
# MAX_MESSAGE_LENGTH=2000
# Cap completion tokens on every LLM call (default 1024)
# LLM_MAX_TOKENS=1024
# Rate limit for POST /api/chat (slowapi format; default 20/minute)
# CHAT_RATE_LIMIT=20/minute
